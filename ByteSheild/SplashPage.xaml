<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="ByteSheild.SplashPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             NavigationPage.HasNavigationBar="False"    
             Shell.NavBarIsVisible="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="100" />
        </Grid.RowDefinitions>
        
        <!-- Dark gradient background with security pattern -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#0B1426" Offset="0" />
                <GradientStop Color="#162236" Offset="0.5" />
                <GradientStop Color="#0B1426" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Security grid pattern background -->
        <Grid x:Name="SecurityGrid" Opacity="0.05">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Horizontal lines -->
            <BoxView Grid.Row="1" Grid.ColumnSpan="4" HeightRequest="1" Color="#00D4AA" />
            <BoxView Grid.Row="2" Grid.ColumnSpan="4" HeightRequest="1" Color="#00D4AA" />
            <BoxView Grid.Row="3" Grid.ColumnSpan="4" HeightRequest="1" Color="#00D4AA" />

            <!-- Vertical lines -->
            <BoxView Grid.Column="1" Grid.RowSpan="4" WidthRequest="1" Color="#00D4AA" />
            <BoxView Grid.Column="2" Grid.RowSpan="4" WidthRequest="1" Color="#00D4AA" />
            <BoxView Grid.Column="3" Grid.RowSpan="4" WidthRequest="1" Color="#00D4AA" />
        </Grid>

        <!-- Main content area -->
        <StackLayout Grid.Row="1" 
                     VerticalOptions="Center" 
                     HorizontalOptions="Center"
                     Spacing="25">

            <!-- Shield icon with glow effect -->
            <Border x:Name="ShieldFrame"
                   BackgroundColor="Transparent"
                   Stroke="Transparent"
                   HeightRequest="120"
                   WidthRequest="120"
                   HorizontalOptions="Center">
                <Border.Shadow>
                    <Shadow Brush="Black" Opacity="0.5" Offset="0,0" Radius="5" />
                </Border.Shadow>
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="50" />
                </Border.StrokeShape>
                <Image x:Name="ShieldIcon"
                       Source="shield_icon.svg" 
                       HeightRequest="100" 
                       WidthRequest="100"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>

            <!-- App title with enhanced styling -->
            <Label x:Name="AppTitle"
                   Text="ByteShield"
                   FontSize="36"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"
                   Opacity="0">
                <Label.Shadow>
                    <Shadow Brush="#00D4AA"
                            Offset="0,0"
                            Radius="10"
                            Opacity="0.5" />
                </Label.Shadow>
            </Label>

            <!-- Enhanced subtitle -->
            <Label x:Name="Subtitle"
                   Text="PERSONAL VAULT"
                   FontSize="14"
                   FontAttributes="Bold"
                   TextColor="#00D4AA"
                   HorizontalOptions="Center"
                   Opacity="0"
                   Margin="0,0,0,20" />

            <!-- Security status indicator -->
            <StackLayout x:Name="SecurityIndicator"
                         Orientation="Horizontal"
                         HorizontalOptions="Center"
                         Spacing="10"
                         Opacity="0">
                <Ellipse Fill="#00D4AA"
                         WidthRequest="8"
                         HeightRequest="8" />
                <Label Text="SECURE CONNECTION"
                       FontSize="12"
                       TextColor="#00D4AA"
                       FontAttributes="Bold" />
            </StackLayout>
        </StackLayout>

        <!-- Loading section -->
        <StackLayout Grid.Row="3"
                     HorizontalOptions="Center"
                     Spacing="15"
                     Opacity="0"
                     x:Name="LoadingSection">

            <!-- Loading text -->
            <Label x:Name="LoadingText"
                   Text="Initializing Security Protocols..."
                   FontSize="14"
                   TextColor="#B0BEC5"
                   HorizontalOptions="Center" />

            <!-- Custom loading animation -->
            <StackLayout Orientation="Horizontal"
                         HorizontalOptions="Center"
                         Spacing="8">
                <Ellipse x:Name="Dot1"
                         Fill="#00D4AA"
                         WidthRequest="8"
                         HeightRequest="8"
                         Opacity="0.3" />
                <Ellipse x:Name="Dot2"
                         Fill="#00D4AA"
                         WidthRequest="8"
                         HeightRequest="8"
                         Opacity="0.3" />
                <Ellipse x:Name="Dot3"
                         Fill="#00D4AA"
                         WidthRequest="8"
                         HeightRequest="8"
                         Opacity="0.3" />
            </StackLayout>
        </StackLayout>

        <!-- Progress bar at bottom -->
        <StackLayout Grid.Row="4" 
                     VerticalOptions="End"
                     Margin="40,0,40,40">
            <ProgressBar x:Name="LoadingProgressBar"
                         Progress="0"
                         ProgressColor="#00D4AA"
                         HeightRequest="4"
                         BackgroundColor="#1A2332" />
        </StackLayout>
    </Grid>
</ContentPage>