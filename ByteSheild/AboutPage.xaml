<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ByteSheild.AboutPage"
             BackgroundColor="#0B1426">

    <Grid>
        <StackLayout VerticalOptions="Start" HorizontalOptions="Center" Spacing="25" Padding="20">
            <Image Source="shield_icon.svg" WidthRequest="120" HeightRequest="120" HorizontalOptions="Center" />
            <Label Text="ByteShield" FontSize="28" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" />
            
            <Label Text="Version 1.0.24 Stable Release" FontSize="14" TextColor="Silver" HorizontalOptions="Center" />
            <Label Text="Developer: Abdullahi Osman" FontSize="14" TextColor="Silver" HorizontalOptions="Center" />

            <StackLayout Spacing="10" Margin="0,30,0,0">
                <Border BackgroundColor="#162236" StrokeThickness="0" Padding="15">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                    <Grid>
                        <Label Text="Privacy Policy" VerticalOptions="Center" FontAttributes="Bold" TextColor="White" />
                        <Label Text=">" HorizontalOptions="End" VerticalOptions="Center" TextColor="#00D4AA" FontAttributes="Bold" />
                    </Grid>
                </Border>

                <Border BackgroundColor="#162236" StrokeThickness="0" Padding="15">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                    <Grid>
                        <Label Text="Open Source Licenses" VerticalOptions="Center" FontAttributes="Bold" TextColor="White" />
                        <Label Text=">" HorizontalOptions="End" VerticalOptions="Center" TextColor="#00D4AA" FontAttributes="Bold" />
                    </Grid>
                </Border>
            </StackLayout>
        </StackLayout>
    </Grid>

</ContentPage>