<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ByteSheild.AddVaultItemPage"
             BackgroundColor="{AppThemeBinding Light=White, Dark=#0B1426}"
             Title="Add Account">
    <ScrollView BackgroundColor="{AppThemeBinding Light=White, Dark=#0B1426}">
        <StackLayout Padding="20" Spacing="20">
            <Label x:Name="HeaderLabel" Text="Add New Account" FontSize="24" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}" />

            <Label Text="Title" TextColor="{AppThemeBinding Light=#505A68, Dark=#A0AAB8}" FontSize="14" Margin="0,10,0,0"/>
            <Border BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#162236}" StrokeThickness="1" Stroke="{AppThemeBinding Light=#D0D5DD, Dark=#2A384D}" Padding="15,0">
                <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                <Entry x:Name="TitleEntry" Placeholder="e.g. Gmail" TextColor="{AppThemeBinding Light=Black, Dark=White}" BackgroundColor="Transparent" />
            </Border>

            <Label Text="Email / Username" TextColor="{AppThemeBinding Light=#505A68, Dark=#A0AAB8}" FontSize="14" />
            <Border BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#162236}" StrokeThickness="1" Stroke="{AppThemeBinding Light=#D0D5DD, Dark=#2A384D}" Padding="15,0">
                <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                <Entry x:Name="EmailEntry" Placeholder="user@example.com" TextColor="{AppThemeBinding Light=Black, Dark=White}" BackgroundColor="Transparent" />
            </Border>

            <Label Text="Password" TextColor="{AppThemeBinding Light=#505A68, Dark=#A0AAB8}" FontSize="14" />
            <Border BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#162236}" StrokeThickness="1" Stroke="{AppThemeBinding Light=#D0D5DD, Dark=#2A384D}" Padding="15,0">
                <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                <Grid ColumnDefinitions="*, Auto">
                    <Entry x:Name="PasswordEntry" Grid.Column="0" IsPassword="True" Placeholder="Secret password" TextColor="{AppThemeBinding Light=Black, Dark=White}" BackgroundColor="Transparent" VerticalOptions="Center" />
                    <ImageButton Grid.Column="1" x:Name="VisibilityToggle" Source="settings_icon.svg" BackgroundColor="Transparent" Padding="10,0" WidthRequest="40" HeightRequest="40" Clicked="OnTogglePasswordVisibility" />
                </Grid>
            </Border>

            <Label Text="Icon (Emoji)" TextColor="{AppThemeBinding Light=#505A68, Dark=#A0AAB8}" FontSize="14" />
            <Border BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#162236}" StrokeThickness="1" Stroke="{AppThemeBinding Light=#D0D5DD, Dark=#2A384D}" Padding="15,0">
                <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                <Entry x:Name="IconEntry" Placeholder="✉️" TextColor="{AppThemeBinding Light=Black, Dark=White}" BackgroundColor="Transparent" />
            </Border>

            <Button Text="Save Securely" BackgroundColor="#00D4AA" TextColor="#0B1426" FontAttributes="Bold" CornerRadius="8" Margin="0,20,0,0" HeightRequest="50" Clicked="OnSaveClicked" />
        </StackLayout>
    </ScrollView>
</ContentPage>


