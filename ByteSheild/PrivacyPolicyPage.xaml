<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ByteSheild.PrivacyPolicyPage"
             Title="Privacy Policy"
             BackgroundColor="{AppThemeBinding Light=White, Dark=#0B1426}">
    <ScrollView BackgroundColor="{AppThemeBinding Light=White, Dark=#0B1426}">
        <StackLayout Padding="20" Spacing="15">
            <Label Text="ByteShield Privacy Policy" FontSize="24" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
            <Label Text="Last Updated: Today" FontSize="14" TextColor="{AppThemeBinding Light=Gray, Dark=Silver}" />
            
            <Label Text="1. Introduction" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}" Margin="0,10,0,0"/>
            <Label Text="Welcome to ByteShield! Your privacy is incredibly important to us. This Privacy Policy outlines what data we handle and how it is protected. Our core philosophy is privacy-first: your offline vault data remains strictly on your device." TextColor="{AppThemeBinding Light=#404040, Dark=#B0BEC5}" />

            <Label Text="2. Data We Collect and Store Locally" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}" Margin="0,10,0,0"/>
            <Label Text="ByteShield provides an offline vault for your sensitive information. All items you save in your vault are stored locally on your device in a secure database. We do not transmit, sync, or backup your vault data to any external server or third-party service." TextColor="{AppThemeBinding Light=#404040, Dark=#B0BEC5}" />

            <Label Text="3. Breach Checker Functionality" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}" Margin="0,10,0,0"/>
            <Label Text="If you choose to use the Data Breach Checker, the email address you enter is sent securely via HTTPS to the 'Have I Been Pwned' (HIBP) API to search for known data breaches. We do not store, log, or share the email address you check, nor do we track your usage of this feature." TextColor="{AppThemeBinding Light=#404040, Dark=#B0BEC5}" />

            <Label Text="4. Device Permissions" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}" Margin="0,10,0,0"/>
            <Label Text="We may request permission to use your device's biometric authentication (like Face ID or Fingerprint) to unlock the app and protect your vault. This biometric data is processed entirely by your device's operating system; ByteShield does not access or store your raw biometric data." TextColor="{AppThemeBinding Light=#404040, Dark=#B0BEC5}" />

            <Label Text="5. Changes to This Policy" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}" Margin="0,10,0,0"/>
            <Label Text="We may update our Privacy Policy from time to time as we add new features. Because the app does not send us your contact info, we encourage you to review this policy periodically within the app." TextColor="{AppThemeBinding Light=#404040, Dark=#B0BEC5}" />

            <Label Text="6. Contact Us" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}" Margin="0,10,0,0"/>
            <Label Text="If you have any questions or concerns about this Privacy Policy or our data practices, please refer to the project repository or developer contacts listed in the About section." TextColor="{AppThemeBinding Light=#404040, Dark=#B0BEC5}" />
        </StackLayout>
    </ScrollView>
</ContentPage>



