<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ByteSheild.OfflineVaultPage"
             BackgroundColor="#0B1426">

    <Grid>
        <Grid RowDefinitions="Auto, Auto, *">
            <!-- Header -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto, Auto" Padding="20,20,20,10" ColumnSpacing="15">
                <Image Grid.Column="0" Source="shield_icon.svg" WidthRequest="32" HeightRequest="32" VerticalOptions="Center" />
                <Label Grid.Column="1" Text="Premium Offline Vault" FontSize="18" FontAttributes="Bold" TextColor="White" VerticalOptions="Center" />

                <Label Grid.Column="2" Text="🔍" FontSize="20" TextColor="#A0AAB8" VerticalOptions="Center" />
                <Label Grid.Column="3" Text="⋮" FontSize="24" TextColor="#A0AAB8" VerticalOptions="Center" />
            </Grid>

            <!-- Section Title -->
            <Label Grid.Row="1" Text="LOCAL ACCOUNTS" FontSize="12" FontAttributes="Bold" TextColor="#00D4AA" Margin="20,10,20,10" CharacterSpacing="1" />

            <!-- CollectionView -->
            <CollectionView x:Name="VaultCollectionView" Grid.Row="2" Margin="20,0,20,0" SelectionMode="Single" SelectionChanged="OnSelectionChanged">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="#1E2A3C" Margin="0,0,0,12" Padding="15" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <!-- Icon container -->
                                <Border WidthRequest="44" HeightRequest="44" BackgroundColor="#2A384D" StrokeThickness="0" VerticalOptions="Center" Margin="0,0,15,0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="10" />
                                    </Border.StrokeShape>
                                    <Label Text="{Binding Icon}" FontSize="24" TextColor="#00D4AA" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>

                                <StackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                    <Label Text="{Binding Title}" FontSize="15" TextColor="White" FontAttributes="Bold" />
                                    <Label Text="{Binding EmailOrUsername}" FontSize="13" TextColor="#A0AAB8" />
                                </StackLayout>

                                <!-- Right side indicator -->
                                <Image Grid.Column="2" Source="shield_icon.svg" WidthRequest="16" HeightRequest="16" VerticalOptions="Center" Opacity="0.8" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.Footer>
                    <StackLayout Padding="0,30,0,100" Spacing="10" HorizontalOptions="Center">
                        <Image Source="shield_icon.svg" WidthRequest="24" HeightRequest="24" HorizontalOptions="Center" Opacity="0.5" />
                        <Label Text="End-to-end encrypted local storage. Your&#10;data never leaves this device." 
                               TextColor="#6A7A90" FontSize="12" HorizontalOptions="Center" HorizontalTextAlignment="Center" LineHeight="1.3" />
                    </StackLayout>
                </CollectionView.Footer>
            </CollectionView>
        </Grid>

        <!-- Floating Action Button -->
        <Button Text="+" TextColor="#0B1426" BackgroundColor="#00D4AA" FontAttributes="Bold" FontSize="36" Padding="0"
                WidthRequest="64" HeightRequest="64" CornerRadius="20" HorizontalOptions="End" VerticalOptions="End" Margin="20,20,20,30"
                Clicked="OnAddClicked">
            <Button.Shadow>
                <Shadow Brush="#00D4AA" Offset="0,4" Radius="15" Opacity="0.2" />
            </Button.Shadow>
        </Button>
    </Grid>
</ContentPage>
