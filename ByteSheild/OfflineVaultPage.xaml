<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ByteSheild.OfflineVaultPage"
             BackgroundColor="{AppThemeBinding Light=White, Dark=#0B1426}">

    <Grid BackgroundColor="{AppThemeBinding Light=White, Dark=#0B1426}">
        <Grid RowDefinitions="Auto, Auto, *">
            <!-- Header -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto, Auto" Padding="20,20,20,10" ColumnSpacing="15">
                <Image Grid.Column="0" Source="shield_icon.svg" WidthRequest="32" HeightRequest="32" VerticalOptions="Center" />
                <Label Grid.Column="1" Text="Premium Offline Vault" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}" VerticalOptions="Center" />

                <Label Grid.Column="2" Text="🔍" FontSize="20" TextColor="{AppThemeBinding Light=#505A68, Dark=#A0AAB8}" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSearchClicked" />
                    </Label.GestureRecognizers>
                </Label>
                <Label Grid.Column="3" Text="⋮" FontSize="24" TextColor="{AppThemeBinding Light=#505A68, Dark=#A0AAB8}" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnOptionsClicked" />
                    </Label.GestureRecognizers>
                </Label>
            </Grid>

            <!-- Section Title -->
            <Label Grid.Row="1" Text="LOCAL ACCOUNTS" FontSize="12" FontAttributes="Bold" TextColor="#00D4AA" Margin="20,10,20,10" CharacterSpacing="1" />

            <!-- CollectionView -->
            <CollectionView x:Name="VaultCollectionView" Grid.Row="2" Margin="20,0,20,0" SelectionMode="None">
                <CollectionView.EmptyView>
                    <StackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="15" Margin="0,50,0,0">
                        <Label Text="📭" FontSize="64" HorizontalOptions="Center" />
                        <Label Text="Your vault is empty" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                        <Label Text="Tap the + button below to add your first secure account." HorizontalOptions="Center" HorizontalTextAlignment="Center" TextColor="{AppThemeBinding Light=#505A68, Dark=#A0AAB8}" Margin="20,0,20,0" />
                    </StackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <SwipeView Margin="0,0,0,12">
                            <SwipeView.RightItems>
                                <SwipeItems Mode="Reveal">
                                    <SwipeItem Text="Password" BackgroundColor="#00D4AA" Invoked="OnShowPasswordInvoked" CommandParameter="{Binding .}" />
                                    <SwipeItem Text="Edit" BackgroundColor="#FF9800" Invoked="OnEditInvoked" CommandParameter="{Binding .}" />
                                    <SwipeItem Text="Delete" BackgroundColor="#F44336" Invoked="OnDeleteInvoked" CommandParameter="{Binding .}" />
                                </SwipeItems>
                            </SwipeView.RightItems>
                            <Border BackgroundColor="{AppThemeBinding Light=#F5F7FA, Dark=#1E2A3C}" Padding="15" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="Auto, *, Auto">
                                    <!-- Icon container -->
                                    <Border WidthRequest="44" HeightRequest="44" BackgroundColor="#2A384D" StrokeThickness="0" VerticalOptions="Center" Margin="0,0,15,0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="10" />
                                        </Border.StrokeShape>
                                        <Label Text="{Binding Icon}" FontSize="24" TextColor="#00D4AA" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>

                                    <StackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                        <Label Text="{Binding Title}" FontSize="15" TextColor="{AppThemeBinding Light=Black, Dark=White}" FontAttributes="Bold" />
                                        <Label Text="{Binding EmailOrUsername}" FontSize="13" TextColor="{AppThemeBinding Light=#505A68, Dark=#A0AAB8}" />
                                    </StackLayout>

                                    <!-- Right side indicator -->
                                    <Label Grid.Column="2" Text="← Swipe" TextColor="{AppThemeBinding Light=#4A5A70, Dark=#6A7A90}" FontSize="10" VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.Footer>
                    <StackLayout Padding="0,30,0,100" Spacing="10" HorizontalOptions="Center">
                        <Image Source="shield_icon.svg" WidthRequest="24" HeightRequest="24" HorizontalOptions="Center" Opacity="0.5" />
                        <Label Text="End-to-end encrypted local storage. Your&#10;data never leaves this device." 
                               TextColor="{AppThemeBinding Light=#4A5A70, Dark=#6A7A90}" FontSize="12" HorizontalOptions="Center" HorizontalTextAlignment="Center" LineHeight="1.3" />
                    </StackLayout>
                </CollectionView.Footer>
            </CollectionView>
        </Grid>

        <!-- Floating Action Button -->
        <Button Text="+" TextColor="#0B1426" BackgroundColor="#00D4AA" FontAttributes="Bold" FontSize="36" Padding="0"
                WidthRequest="64" HeightRequest="64" CornerRadius="20" HorizontalOptions="End" VerticalOptions="End" Margin="20,20,20,30"
                Clicked="OnAddClicked">
            <Button.Shadow>
                <Shadow Brush="#00D4AA" Offset="0,4" Radius="15" Opacity="0.2" />
            </Button.Shadow>
        </Button>
    </Grid>
</ContentPage>



